              --prefix PATH : ${pkgs.lib.makeBinPath [ pkgs.dialog pkgs.git pkgs.nix pkgs.coreutils ]}
          '';
        };
      });

    apps = forEachSystem (system: let pkgs = import nixpkgs { inherit system; }; in {
