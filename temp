      let pkgs = import nixpkgs { inherit system; };
      in {
        nyx-tui = pkgs.stdenv.mkDerivation {
          pname = "nyx-tui";
          version = "0.1.0";
          src = ./.;
          nativeBuildInputs = [ pkgs.makeWrapper ];
          installPhase = ''
