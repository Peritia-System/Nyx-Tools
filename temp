# nyx-tui.nix (Nix module)

{ config, lib, pkgs, ... }:
let
  cfg = config.programs.nyx.tui;
in
{
  options.programs.nyx.tui = {
    enable = lib.mkEnableOption "Enable Nyx TUI (nyx-tui)";
    packageName = lib.mkOption {
      type = lib.types.str;
      default = "nyx-tui";
      description = "Name of the package to install (for overrides).";
    };
    logDir = lib.mkOption {
      type = lib.types.path;
      default = /var/log/nyx;
      description = "Where the TUI looks for logs.";
    };
  };

  config = lib.mkIf cfg.enable {
    environment.systemPackages = [
      (pkgs.stdenv.mkDerivation {
        pname = cfg.packageName;
        version = "0.1.0";
        src = ./.;

        nativeBuildInputs = [ pkgs.makeWrapper ];
        buildInputs = [ ];

        installPhase = ''
          mkdir -p $out/bin
          # ship the script
          cp ${./nyx-tui.sh} $out/bin/nyx-tui
          chmod +x $out/bin/nyx-tui

          # wrap with runtime deps
          makeWrapper $out/bin/nyx-tui $out/bin/nyx-tui \
            --set NYX_LOG_DIR ${toString cfg.logDir} \
            --prefix PATH : ${lib.makeBinPath [
              pkgs.dialog
              pkgs.git
              pkgs.nix
              pkgs.coreutils
              pkgs.util-linux
              pkgs.findutils
              pkgs.gnugrep
              pkgs.gawk
              pkgs.ncurses
            ]}
        '';
      })
    ];

    # Optional: handy alias
    environment.shellAliases.nyx-tui = "nyx-tui";
  };
}

